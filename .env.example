# ===========================================
# Salud Digital - Variables de Entorno
# ===========================================
# Copia este archivo a .env y configura los valores

# Base de datos PostgreSQL
# Formato: postgresql://usuario:password@host:puerto/nombre_db
DATABASE_URL=postgresql://salud_digital:TU_PASSWORD@localhost:5432/salud_digital

# Clave secreta para sesiones (genera con: openssl rand -hex 32)
# OBLIGATORIO en producción
SESSION_SECRET=

# Entorno de ejecución
NODE_ENV=production

# Puerto de la aplicación (Nginx hace proxy a este puerto)
PORT=5000

# Pool de conexiones a la base de datos
DB_POOL_MAX=20
DB_POOL_MIN=2

# Nivel de logging: debug, info, warn, error
LOG_LEVEL=info

# Contraseña para el usuario admin inicial
# Solo necesario en el primer despliegue
ADMIN_PASSWORD=
